{
  "name": "mth-apclient",
  "version-string": "0.1.0-dev",
  "dependencies": [],
  "features": {
    "net": {
      "description": "Archipelago networking (apclientpp transport + TLS)",
      "dependencies": [
        "asio",
        "openssl",
        "zlib",
        "nlohmann-json"
      ]
    },
    "overlay": {
      "description": "In-game Dear ImGui dev overlay (Vulkan + SDL2 input)",
      "dependencies": [
        "vulkan-headers",
        {
          "name": "sdl2",
          "default-features": false
        }
      ]
    }
  }
}
